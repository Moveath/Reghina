# Порт, на котором слушает Express. Не 3000 — этот порт нередко занят
# сторонним софтом (VPN-клиенты, другие dev-серверы); значение должно
# совпадать с API_BASE_URL в js/ui/letters.js на фронтенде.
PORT=3001

# Домен фронтенда — разрешаем ему обращаться к API (CORS).
# Для локальной разработки через Live Server обычно так:
CLIENT_ORIGIN=http://127.0.0.1:5500

# Supabase (Project Settings -> API в панели Supabase)
# ВАЖНО: сюда идёт secret key (новый формат ключей Supabase, начинается на
# sb_secret_...), а не publishable/anon key — сервер обращается к базе от
# имени бэкенда и обходит RLS, фронтенд напрямую в Supabase не ходит.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-secret-key

# Telegram-бот, через которого собака относит письма Регины Егору и
# принимает его ответы (long polling, вебхук не используется).
# Токен — от @BotFather. EGOR_TELEGRAM_ID — числовой id Егора в Telegram
# (например, через @userinfobot); ВАЖНО: Егор должен хотя бы раз сам
# написать боту (/start) — иначе бот не сможет написать ему первым.
TELEGRAM_BOT_TOKEN=your-bot-token
EGOR_TELEGRAM_ID=your-telegram-id
